# Exclude everything by default
*
!.gitignore

# Secrets — never commit
.env
.dev.vars

# Include HTML files
!*.html

# Include documentation
!CLAUDE.md

# Include root-level serverless functions and assets
!functions/
!functions/api/
!functions/api/nfts.js
!functions/api/explore.js
!functions/api/wallet-collections.js
!a-logo.png

# Include deploy/ — production folder
# .wrangler/ is re-ignored below after the broad un-ignore
!deploy/
!deploy/**
deploy/.wrangler/
